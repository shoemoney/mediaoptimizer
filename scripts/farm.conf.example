# farm.conf — deployment config for the distributed HEVC farm.
# Copy to farm.conf and edit. farm.conf is gitignored — keep your real IPs/library private.
# This file is sourced by farm-deploy.sh (plain bash; arrays allowed).

# launchd label + the user the per-node daemon runs as (must have passwordless ssh to the NAS)
LABEL="com.example.hevc-farm"
NODE_USER="you"

# per-node install dir (holds the worker script, state, logs) + path to bash 5+ on each node
NODE_DIR="/Users/you/hevc-farm"
NODE_BASH="/opt/homebrew/bin/bash"

# the NAS (file server): ssh host, media library root, shared progress-state file
NAS="nas.lan"
REMOTE_ROOT="/srv/media/TV"
STATE_REMOTE="/srv/media/TV/.hevc-farm-state.tsv"

# persistent ffmpeg container on the NAS used for fast remote probing (docker exec)
PROBE_CTR="hevc-probe"
# If that container sees the library at a different mount than the NAS host path, set both so
# state keys line up (host prefix -> container prefix). Leave as "/" for no remapping.
MEDIA_HOST="/srv/media"
MEDIA_CANON="/media"

VT_QUALITY="60"   # hevc_videotoolbox -q:v (1-100, higher = better/bigger). The 1080p tier default.

# ---- optional knobs (all have sane defaults; uncomment to change) ----
# VT_CODEC="hevc"        # hevc | av1  (#12; av1_videotoolbox needs an M3+ media engine)
# VMAF_MIN="0"           # >0 turns on the perceptual quality gate (#1): reject any encode whose
#                        # mean VMAF vs the source falls below this (e.g. 93). Slow (whole-file). Off by default.
# Q_VT_2160="50"; Q_VT_SD="63"   # per-resolution quality tiers (#4); only bite if you raise MAX_H to KEEP 4K
# QUEUE_POLL_SECS="60"   # how often workers check the import queue between full rescans (#16)
# SPACE_GUARD="1"        # skip a file if the worker's local disk can't hold ~2.2x its size (on by default)
# EXCLUDE=""             # newline-separated globs; matching library paths are never touched (keep a grain master)
#
# --- farm worker: pause while Plex is streaming (optional) ---
# PLEX_PAUSE="0"         # 1 = wait while Plex has a live transcode before pulling/encoding
# PLEX_URL="http://NAS:32400"; PLEX_TOKEN=""; MAX_PLEX_WAIT_MIN="120"
#
# --- farm worker: tell *arr to re-read the file after replace (optional, debounced 1/pass) ---
# ARR_URL="http://nas:8989"; ARR_KEY="<api-key>"; ARR_KIND="sonarr"   # sonarr | radarr
#
# --- farm-watchdog.sh (#7), read when you cron it on the control box ---
# NTFY_URL="https://ntfy.sh/your-topic"   # alert channel for unhealthy/revived nodes (empty = log only)
# HEARTBEAT_URL="https://hc-ping.com/<uuid>"  # pinged ONLY when all nodes healthy (dead-man switch)
#
# --- farm-deploy reverify (sample-decode converted files for silent corruption) ---
# REVERIFY_SAMPLE="20"; REVERIFY_SECS="20"    # how many done-files to spot-check, seconds each
#
# --- hevc-digest.sh (daily savings report) / hevc-estimate.sh (dry-run projection) ---
# SINCE_HOURS="24"       # digest window
# EST_RATIO="0.42"       # estimator's assumed output/source size ratio (~58% smaller)

# ---- nodes: one entry per Apple Silicon Mac ----
HOSTS=(10.0.0.11 10.0.0.12 10.0.0.13)

# concurrent encodes per node (an Ultra handles ~3; a Max / laptop ~2)
declare -A CONC=( [10.0.0.11]=3 [10.0.0.12]=3 [10.0.0.13]=2 )

# DISJOINT slice of library subdirectories per node (newline-separated, exact dir names under REMOTE_ROOT)
declare -A SLICE
SLICE[10.0.0.11]='Show One
Show Two'
SLICE[10.0.0.12]='Show Three
Show Four'
SLICE[10.0.0.13]='Show Five'
